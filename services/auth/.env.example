DATABASE_URL="postgresql://quickdrop:quickdrop_dev@localhost:5432/quickdrop"
JWT_ACCESS_SECRET="change-me-access-secret-key-quickdrop-dev"
JWT_REFRESH_SECRET="change-me-refresh-secret-key-quickdrop-dev"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV=development

# ---------- 速率限制配置（可选，下方为默认值）----------
# RATE_LIMIT_REGISTER_WINDOW_MS=3600000      # 注册窗口 1 小时
# RATE_LIMIT_REGISTER_MAX=5                   # 注册 5 次/窗口
# RATE_LIMIT_LOGIN_WINDOW_MS=60000            # 登录窗口 1 分钟
# RATE_LIMIT_LOGIN_MAX=10                     # 登录 10 次/窗口
# RATE_LIMIT_CHANGE_PASSWORD_WINDOW_MS=60000  # 改密窗口 1 分钟
# RATE_LIMIT_CHANGE_PASSWORD_MAX=3            # 改密 3 次/窗口
# RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=3600000 # 找回密码窗口 1 小时
# RATE_LIMIT_FORGOT_PASSWORD_MAX=3            # 找回密码 3 次/窗口
# RATE_LIMIT_RESET_PASSWORD_WINDOW_MS=3600000 # 重置密码窗口 1 小时
# RATE_LIMIT_RESET_PASSWORD_MAX=5             # 重置密码 5 次/窗口
