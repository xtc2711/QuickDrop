# ============================================================
# QuickDrop 生产环境 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 数据库 ----
# PostgreSQL 连接字符串（Prisma 格式）
DATABASE_URL=postgresql://quickdrop:CHANGE_ME_DB_PASSWORD@postgres:5432/quickdrop?schema=public

# ---- Redis ----
# Redis 连接字符串（用于 Token 黑名单、速率限制）
REDIS_URL=redis://redis:6379/0

# ---- JWT 密钥（至少 64 字符随机字符串）----
# 生成方式: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_64_CHARS

# Token 有效期
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- 邮件服务（SMTP，用于密码重置）----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@quickdrop.app
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=QuickDrop <noreply@quickdrop.app>

# ---- 应用配置 ----
NODE_ENV=production
APP_BASE_URL=https://quickdrop.app

# ---- 服务端口（Docker 内部网络）----
# 认证服务端口
AUTH_PORT=3001
# 信令服务端口
SIGNAL_PORT=3002

# ---- 信令服务地址（认证服务内部调用）----
SIGNAL_SERVICE_URL=http://signal:3002

# ---- 心跳配置（毫秒）----
HEARTBEAT_INTERVAL_MS=15000
HEARTBEAT_TIMEOUT_MS=30000

# ---- TURN/STUN 服务器配置 ----
# 桌面端 Web 前端的 VITE 环境变量
VITE_QD_STUN_SERVERS=stun:stun.quickdrop.app:3478,stun:stun.l.google.com:19302
VITE_QD_TURN_SERVERS=turn:turn.quickdrop.app:3478?transport=udp,turn:turn.quickdrop.app:3478?transport=tcp
VITE_QD_TURN_USERNAME=quickdrop
VITE_QD_TURN_CREDENTIAL=CHANGE_ME_TURN_PASSWORD

# ---- 数据库密码（PostgreSQL）----
POSTGRES_USER=quickdrop
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=quickdrop

# ---- Let's Encrypt（可选）----
# 证书申请邮箱
LETSENCRYPT_EMAIL=admin@quickdrop.app
